{
  "name": "hoyofetch",
  "version": "2.0.0",
  "description": "HoYoverse redemption code fetcher bot for Revolt/Stoat.chat",
  "main": "bot.js",
  "type": "module",
  "scripts": {
    "start": "node bot.js",
    "dev": "node --watch bot.js",
    "test": "node --test",
    "lint": "eslint .",
    "docs:build": "ASTRO_TELEMETRY_DISABLED=1 npm --prefix website run check",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "node-fetch": "^3.3.2",
    "revolt.js": "^7.0.4",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "globals": "^15.0.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
