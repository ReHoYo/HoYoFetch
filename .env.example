# ─── HoYoFetch Configuration ───────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Your Revolt bot token (required)
BOT_TOKEN=your_bot_token_here

# Command prefix (default: /)
PREFIX=/

# How often to auto-fetch new codes, in minutes (default: 60)
FETCH_INTERVAL=60

# Minimum seconds between manual /Fetch* commands per channel (default: 10, 0 disables)
FETCH_COOLDOWN=10

# Emoji style: "unicode" for fallback emoji, "custom" for Revolt server emoji
# See config.js for instructions on setting up custom emoji
EMOJI_MODE=unicode

# ─── Audit log (/Enable-AuditLog) ──────────────────

# Bot-owner account that approves privacy channel exclusions. If omitted,
# Irminsul resolves the bot owner from Stoat at startup.
CUSTODIAN_USER_ID=

# Verbose per-event console logging for the audit log (1 = on, default: off)
AUDITLOG_DEBUG=

# Max size (MB) of a single attachment to preserve as delete-evidence (default: 20, Stoat's own upload limit)
AUDITLOG_EVIDENCE_MAX_MB=20

# Total disk budget (MB) for all preserved attachment evidence, oldest evicted first (default: 1024; 0 disables evidence capture)
AUDITLOG_EVIDENCE_BUDGET_MB=1024
